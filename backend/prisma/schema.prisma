generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())

  wallet    String   @unique
  role      String
  name      String

  createdAt DateTime @default(now())
}

model Claim {
  id              Int      @id @default(autoincrement())

  blockchainId    BigInt   @unique

  hospitalWallet  String
  insurerWallet   String

  amount          Float
  status          String

  createdAt       DateTime @default(now())
}

model ClaimToken {
  id        Int      @id @default(autoincrement())

  tokenId   BigInt   @unique
  claimId   BigInt

  owner     String

  createdAt DateTime @default(now())
}

model Settlement {
  id        Int      @id @default(autoincrement())

  tokenId   BigInt   @unique

  amount    Float

  payer     String
  payee     String

  createdAt DateTime @default(now())
}