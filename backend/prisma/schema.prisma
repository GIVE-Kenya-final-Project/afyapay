generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id          String @id @default(cuid())

  wallet      String @unique

  role        String

  createdAt   DateTime @default(now())
}

model Claim {
  id              Int @id @default(autoincrement())

  blockchainId    Int

  hospitalWallet  String

  insurerWallet   String

  amount          Float

  status          String

  createdAt       DateTime @default(now())
}

model ClaimToken {
  id        Int @id @default(autoincrement())

  tokenId   Int

  claimId   Int

  owner     String
}

model Settlement {
  id        Int @id @default(autoincrement())

  tokenId   Int

  amount    Float

  payer     String

  payee     String
}